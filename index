<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HKDSE Econ: Minimum Wage Interactive Lab</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            max-width: 600px;
            margin: 40px auto;
            padding: 20px;
            border-radius: 12px;
            background: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        h1 { color: #2c3e50; text-align: center; }
        .market-env { background: #ecf0f1; padding: 15px; border-radius: 8px; margin: 20px 0; }
        .slider-container { margin: 25px 0; text-align: center; }
        input[type=range] { width: 80%; margin-top: 10px; }
        .result-box {
            padding: 15px;
            border-radius: 8px;
            font-weight: bold;
            text-align: center;
            font-size: 1.1em;
        }
        .ineffective { background-color: #ffeaa7; color: #d35400; }
        .effective { background-color: #ff7675; color: #c0392b; }
        .equilibrium { background-color: #55efc4; color: #00b894; }
    </style>
</head>
<body>

    <h1>Minmium-Wage-Generator-HKDSE</h1>
    <p style="text-align: center; color: #7f8c8d;">Market Intervention — Statutory Minimum Wage</p>
    
    <div class="market-env">
        <p>📊 <strong>Market Condition:</strong><br>
        Equilibrium Wage: <strong>$60 / hr</strong><br>
        Labor Supplied: 100,000 workers<br>
        Labor Demanded: 100,000 workers</p>
    </div>

    <div class="slider-container">
        <label for="wageSlider">Set the Minimum Wage: <strong>$<span id="wageVal">60</span> / hr</strong></label><br>
        <input type="range" id="wageSlider" min="40" max="90" value="60">
    </div>

    <div id="result" class="result-box equilibrium">
        Market is at Equilibrium. Employment is maximized!
    </div>

    <script>
        // Game Logic
        var slider = document.getElementById('wageSlider');
        var wageVal = document.getElementById('wageVal');
        var result = document.getElementById('result');

        slider.oninput = function() {
            var currentWage = parseInt(this.value);
            wageVal.innerHTML = currentWage;

            if (currentWage === 60) {
                result.innerHTML = "🎯 Market is at Equilibrium. No deadweight loss!";
                result.className = "result-box equilibrium";
            } 
            else if (currentWage < 60) {
                result.innerHTML = "⚠️ Ineffective Minimum Wage!<br>Because $" + currentWage + " is BELOW the equilibrium wage ($60), market forces pull it back to $60. No structural unemployment.";
                result.className = "result-box ineffective";
            } 
            else {
                var gap = (currentWage - 60) * 5000;
                result.innerHTML = "🚨 Effective Minimum Wage!<br>Because $" + currentWage + " is ABOVE equilibrium ($60):<br>• Quantity Supplied > Quantity Demanded<br>• Result: A Surplus of Labor of " + gap + " workers (Unemployment)!";
                result.className = "result-box effective";
            }
        }
    </script>
</body>
</html>
